<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7F1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/one_fold_title"
            android:textColor="#1C1917"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/angle_picker_instruction"
            android:textColor="#57534E"
            android:textSize="16sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/trayWidthInputLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/tray_width_hint"
            app:boxStrokeColor="#C2410C"
            app:helperText="@string/tray_width_helper">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/trayWidthInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:inputType="none"
                android:maxLines="1"
                android:textColor="#1C1917"
                android:textColorHint="#78716C" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/angleValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#FDE7D8"
            android:clickable="true"
            android:focusable="true"
            android:minWidth="120dp"
            android:paddingHorizontal="18dp"
            android:paddingVertical="10dp"
            android:text="@string/angle_value_default"
            android:textAlignment="center"
            android:textColor="#9A3412"
            android:textSize="34sp"
            android:textStyle="bold" />

        <com.example.risksiteapp.AnglePickerView
            android:id="@+id/anglePickerView"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="28dp"
            android:background="#FDE7D8"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/resultLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/result_label"
                android:textColor="#7C2D12"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/resultValueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/result_value_default"
                android:textColor="#9A3412"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
